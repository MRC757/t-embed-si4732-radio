{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ES2022",
    "moduleResolution":  "bundler",
    "lib":               ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "strict":            true,
    "noEmit":            true,
    "noUnusedLocals":    true,
    "noUnusedParameters": true
  },
  "include": ["src/**/*.ts", "vite.config.ts"]
}
