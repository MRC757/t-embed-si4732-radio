{
  "name": "js8call-browser-decoder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm:build":  "cd wasm && wasm-pack build --target web --out-dir ../wasm/pkg",
    "dev":         "npm run wasm:build && vite",
    "build":       "npm run wasm:build && vite build",
    "preview":     "vite preview",
